# App
APP_NAME=RegIQ
APP_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True

# Observability via LangSmith
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=RegIQ

# AI/ML API (OpenAI-compatible)
AIML_API_KEY=
OPENAI_BASE_URL=https://api.aimlapi.com/v1

# Model routing
MODEL_FAST=gpt-4o-mini
MODEL_BALANCED=anthropic/claude-sonnet-4.6
MODEL_EMBEDDINGS=text-embedding-3-small

# Qdrant Cloud
QDRANT_API_KEY=
QDRANT_CLUSTER_ENDPOINT=
QDRANT_COLLECTION=regiq_company_kb

# Band (Thenvoi) Platform
THENVOI_REST_URL=https://app.band.ai/
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket

# Band Agent Credentials (generated to configs/agent_config.yaml at runtime)
BAND_MONITOR_AGENT_ID=
BAND_MONITOR_API_KEY=
BAND_LEGAL_PARSER_AGENT_ID=
BAND_LEGAL_PARSER_API_KEY=
BAND_IMPACT_MAPPER_AGENT_ID=
BAND_IMPACT_MAPPER_API_KEY=
BAND_GAP_ANALYST_AGENT_ID=
BAND_GAP_ANALYST_API_KEY=
BAND_REMEDIATION_PLANNER_AGENT_ID=
BAND_REMEDIATION_PLANNER_API_KEY=

# Production URL (set after deployment)
REGIQ_API_BASE_URL=http://localhost:8000